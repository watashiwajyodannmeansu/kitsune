{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "process",
      "label": "C/C++: gcc build active file",
      "command": "/usr/bin/gcc",
      "args": ["-g", "-O0", "${file}", "-o", "${fileDirname}/${fileBasenameNoExtension}.exe"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$msCompile"]
    }
  ]
}
